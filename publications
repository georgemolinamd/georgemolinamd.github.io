<script>
  function filterPubs(filter, btn) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    let visible = 0;
    document.querySelectorAll('.pub-item').forEach(item => {
      const yr = parseInt(item.dataset.year);
      let show = true;
      if (filter === '2024') show = yr >= 2024;
      else if (filter === '2022') show = yr >= 2022 && yr < 2024;
      else if (filter === 'older') show = yr < 2022;
      item.style.display = show ? 'grid' : 'none';
      if (show) visible++;
    });
    document.getElementById('pubCount').textContent = visible + ' publication' + (visible !== 1 ? 's' : '');
  }

  // Run on load to set count
  window.addEventListener('DOMContentLoaded', () => {
    const allBtn = document.querySelector('.filter-btn.active');
    filterPubs('all', allBtn);
  });
</script>
