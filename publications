    --cream: #f7f4ef; --cream-dark: #ede9e1;
    --text: #1c1c1c; --text-muted: #5a5a5a; --text-light: #8a8a8a;
    --border: #d8d2c8;
    --serif: 'EB Garamond', Georgia, serif;
    --display: 'Cormorant Garamond', Georgia, serif;
    --mono: 'JetBrains Mono', monospace;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--serif); background: var(--navy); color: var(--text); font-size: 18px; line-height: 1.75; }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--navy); border-bottom: 1px solid var(--navy-light); display: flex; align-items: center; justify-content: space-between; padding: 0 3rem; height: 56px; }
  .nav-brand { font-family: var(--display); font-size: 17px; font-weight: 400; color: var(--cream); letter-spacing: 0.04em; text-decoration: none; }
  .nav-brand span { color: var(--gold-light); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { font-family: var(--mono); font-size: 11.5px; color: #9bb0c4; text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s; }
  .nav-links a:hover { color: var(--gold-light); }
  .nav-links a.active { color: var(--gold-light); }

  /* PAGE HEADER */
  .page-header { padding: 8rem 3rem 4rem; max-width: 960px; margin: 0 auto; }
  .page-eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem; }
  .page-eyebrow::after { content: ''; display: inline-block; height: 1px; width: 48px; background: var(--gold); opacity: 0.5; }
  h1.page-title { font-family: var(--display); font-size: clamp(2.5rem, 4vw, 4rem); font-weight: 300; color: var(--cream); line-height: 1.1; margin-bottom: 1rem; }
  .page-desc { font-size: 1rem; color: #7a9ab5; max-width: 540px; line-height: 1.8; }

  /* PUBLICATIONS */
  .pub-section { max-width: 960px; margin: 0 auto; padding: 0 3rem 5rem; }
  .pub-filters { display: flex; gap: 8px; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .filter-btn { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--navy-light); background: transparent; color: #7a9ab5; padding: 6px 16px; cursor: pointer; transition: all 0.2s; }
  .filter-btn.active, .filter-btn:hover { background: var(--gold); border-color: var(--gold); color: var(--navy); }
  .pub-list { display: flex; flex-direction: column; }
  .pub-item { border-top: 1px solid var(--navy-light); padding: 1.5rem 0; display: grid; grid-template-columns: 56px 1fr; gap: 1.5rem; align-items: start; }
  .pub-item:last-child { border-bottom: 1px solid var(--navy-light); }
  .pub-year { font-family: var(--mono); font-size: 12px; color: var(--gold); padding-top: 4px; letter-spacing: 0.05em; }
  .pub-title { font-family: var(--serif); font-size: 1.05rem; font-style: italic; color: var(--cream); margin-bottom: 0.3rem; line-height: 1.45; }
  .pub-authors { font-size: 0.88rem; color: #7a9ab5; margin-bottom: 0.25rem; }
  .pub-authors strong { color: #a8c4d8; font-style: normal; font-weight: 500; }
  .pub-journal { font-size: 0.85rem; color: #5a7a8f; font-style: italic; }
  .pub-links { display: flex; gap: 10px; margin-top: 0.5rem; flex-wrap: wrap; }
  .pub-link { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold-light); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s; }
  .pub-link:hover { border-bottom-color: var(--gold-light); }
  .pub-badge { font-family: var(--mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.08em; padding: 2px 8px; border: 1px solid #3a5a2a; color: #7ab87a; vertical-align: middle; margin-left: 8px; }
  .pub-count { font-family: var(--mono); font-size: 11px; color: #3a5068; margin-bottom: 1.5rem; }

  /* FOOTER */
  footer { background: var(--navy); border-top: 1px solid var(--navy-light); padding: 2rem 3rem; display: flex; align-items: center; justify-content: space-between; }
  .footer-copy { font-family: var(--mono); font-size: 11px; color: #3a5068; letter-spacing: 0.06em; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-family: var(--mono); font-size: 11px; color: #3a5068; text-decoration: none; letter-spacing: 0.06em; transition: color 0.2s; }
  .footer-links a:hover { color: var(--gold-light); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .page-header { animation: fadeUp 0.7s ease both; }

  @media (max-width: 768px) {
    nav { padding: 0 1.5rem; }
    .nav-links { gap: 1rem; }
    .page-header, .pub-section { padding-left: 1.5rem; padding-right: 1.5rem; }
    footer { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
